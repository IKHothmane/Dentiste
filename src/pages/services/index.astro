---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { AppointmentButton } from "../../components/AppointmentButton";

const services = [
  {
    title: "Soins Préventifs",
    icon: "shield_with_heart",
    description: "Bilans de routine, détartrages et examens pour garder vos dents et gencives en bonne santé.",
    href: "/services/soins-preventifs"
  },
  {
    title: "Soins Restaurateurs",
    icon: "medical_services",
    description: "Caries, couronnes, inlays/onlays et prothèses pour restaurer la fonction et l'esthétique de vos dents.",
    href: "/services/soins-restaurateurs"
  },
  {
    title: "Dentisterie Esthétique",
    icon: "auto_awesome",
    description: "Sublimez votre sourire avec des facettes, remodelage et bien plus encore.",
    href: "/services/dentisterie-esthetique"
  },
  {
    title: "Invisalign",
    icon: "straighten",
    description: "Alignez vos dents confortablement avec des gouttières transparentes et amovibles.",
    href: "/services/invisalign"
  },
  {
    title: "Blanchiment Dentaire",
    icon: "light_mode",
    description: "Des traitements sûrs et efficaces pour un sourire plus éclatant et confiant.",
    href: "/services/blanchiment-dentaire"
  },
  {
    title: "Implants Dentaires",
    icon: "dentistry",
    description: "Des remplacements permanents et d'apparence naturelle pour les dents manquantes.",
    href: "/services/implants-dentaires"
  },
  {
    title: "Dentisterie Pédiatrique",
    icon: "sentiment_satisfied",
    description: "Des soins doux et amicaux conçus pour garder le sourire de votre enfant en bonne santé.",
    href: "/services/pediatrie"
  }
];
---

<BaseLayout title="Services - Dr PINTO KAREN">
  <Header />

  <main class="min-h-screen">
    <section class="w-full bg-surface">
      <div class="w-full px-4 sm:px-8 lg:px-12 py-12 md:py-16 flex flex-col lg:flex-row gap-12 lg:gap-16">
        <div class="lg:w-[40%] flex flex-col justify-start">
          <span class="text-primary font-extrabold text-label-md uppercase tracking-[0.15em] mb-6 block">SOLUTIONS DENTAIRES COMPLÈTES</span>
          <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg font-extrabold text-on-surface mb-8 leading-[1.05] tracking-tighter">
            Des Soins<br />
            Sur-Mesure<br />
            Pour Chaque <span class="text-primary relative inline-block">
              Sourire
              <svg class="absolute w-full h-4 -bottom-1 left-0 text-primary/30" preserveAspectRatio="none" viewBox="0 0 100 10">
                <path d="M0,5 Q50,10 100,5" fill="transparent" stroke="currentColor" stroke-width="3"></path>
              </svg>
            </span>
          </h1>

          <p class="text-body-lg text-on-surface-variant/80 mb-12 max-w-md leading-relaxed font-medium">
            Des soins préventifs aux traitements avancés, nous offrons une gamme complète de services pour garder votre sourire sain, confiant et éclatant.
          </p>

          <div class="flex items-center gap-6 mb-16 flex-wrap">
            <AppointmentButton client:load label="Prendre RDV" phone="05 22 20 26 12" />
            <a class="text-on-surface-variant hover:text-primary font-bold text-body-md flex items-center gap-2 group transition-colors" href="/contact">
              Contact
              <span class="material-symbols-outlined text-[22px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          </div>

          <div class="mt-auto pt-10 border-t border-outline-variant/30">
            <h2 class="text-primary font-extrabold text-label-md uppercase tracking-wider mb-6">Pourquoi les patients nous font confiance</h2>
            <ul class="space-y-4">
              <li class="flex items-center gap-3 text-on-surface-variant font-semibold text-body-md">
                <span class="material-symbols-outlined text-primary text-[24px]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Équipe expérimentée et bienveillante
              </li>
              <li class="flex items-center gap-3 text-on-surface-variant font-semibold text-body-md">
                <span class="material-symbols-outlined text-primary text-[24px]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Technologie de pointe
              </li>
              <li class="flex items-center gap-3 text-on-surface-variant font-semibold text-body-md">
                <span class="material-symbols-outlined text-primary text-[24px]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Soins personnalisés pour tous les âges
              </li>
            </ul>
          </div>
        </div>

        <div class="lg:w-[60%]">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {services.map((service) => (
              <a
                class="bg-surface-container-lowest border border-outline-variant/40 rounded-3xl p-8 flex flex-col items-center text-center h-full transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-primary/20"
                href={service.href}
              >
                <div class="w-20 h-20 rounded-2xl bg-primary/5 flex items-center justify-center text-primary mb-6">
                  <span class="material-symbols-outlined text-[40px]">{service.icon}</span>
                </div>
                <h3 class="text-headline-md font-extrabold text-on-surface mb-3">{service.title}</h3>
                <p class="text-body-md font-medium text-on-surface-variant/70 mb-8 flex-grow leading-relaxed">
                  {service.description}
                </p>
                <span class="text-primary font-bold text-label-md uppercase tracking-wider flex items-center gap-2 group mt-auto hover:text-on-primary-fixed-variant transition-colors">
                  En savoir plus
                  <span class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </span>
              </a>
            ))}

            <div class="bg-error/5 border border-error/20 rounded-3xl p-8 flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left h-full md:col-span-2">
              <div class="w-20 h-20 sm:w-24 sm:h-24 shrink-0 rounded-2xl bg-error/10 flex items-center justify-center text-error mb-6 sm:mb-0 sm:mr-8">
                <span class="material-symbols-outlined text-[44px]">medical_services</span>
              </div>
              <div class="flex flex-col flex-grow justify-center">
                <h3 class="text-headline-md font-extrabold text-on-surface mb-3">Urgences</h3>
                <p class="text-body-md font-medium text-on-surface-variant/80 mb-0 max-w-2xl leading-relaxed">
                  Rendez-vous le jour même pour les douleurs dentaires, blessures et autres problèmes urgents.
                </p>
              </div>
              <a class="text-error font-extrabold text-label-md uppercase tracking-wider flex items-center gap-2 group mt-8 sm:mt-0 sm:self-center bg-error/5 px-6 py-3 rounded-xl hover:bg-error/10 transition-colors" href="tel:0522202612">
                Appeler
                <span class="material-symbols-outlined text-[20px] group-hover:translate-x-1 transition-transform">call</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="w-full border-t border-outline-variant/30 bg-surface-container-low/30">
      <div class="w-full px-4 sm:px-8 lg:px-12 py-12 flex flex-wrap justify-center md:justify-between items-center gap-10">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
            <span class="material-symbols-outlined text-[24px]" style="font-variation-settings: 'FILL' 1;">verified_user</span>
          </div>
          <div>
            <span class="block text-body-md font-extrabold text-on-surface leading-tight">Plébiscité par</span>
            <span class="block text-label-md font-bold text-on-surface-variant/60 uppercase tracking-widest mt-0.5">1,000+ Patients</span>
          </div>
        </div>

        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
            <span class="material-symbols-outlined text-[24px]" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <div>
            <span class="block text-body-md font-extrabold text-on-surface leading-tight">5 Étoiles</span>
            <span class="block text-label-md font-bold text-on-surface-variant/60 uppercase tracking-widest mt-0.5">Avis Google</span>
          </div>
        </div>

        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
            <span class="material-symbols-outlined text-[24px]" style="font-variation-settings: 'FILL' 1;">fact_check</span>
          </div>
          <div>
            <span class="block text-body-md font-extrabold text-on-surface leading-tight">Conventionné</span>
            <span class="block text-label-md font-bold text-on-surface-variant/60 uppercase tracking-widest mt-0.5">Tiers Payant</span>
          </div>
        </div>

        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
            <span class="material-symbols-outlined text-[24px]" style="font-variation-settings: 'FILL' 0;">schedule</span>
          </div>
          <div>
            <span class="block text-body-md font-extrabold text-on-surface leading-tight">Horaires Souples</span>
            <span class="block text-label-md font-bold text-on-surface-variant/60 uppercase tracking-widest mt-0.5">Semaine &amp; Samedi</span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
