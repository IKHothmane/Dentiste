---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { AppointmentButton } from "../../../components/AppointmentButton";
---

<BaseLayout title="Implants Dentaires | Dr PINTO KAREN - Chirurgien Dentiste">
  <Header />

  <main class="w-full">
    <section class="bg-soft-gradient py-section-padding overflow-hidden">
      <div class="w-full px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div class="space-y-8">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full font-label-md text-label-md font-bold">
            <span class="material-symbols-outlined text-[18px]">workspace_premium</span>
            SOLUTIONS DENTAIRES COMPLÈTES
          </div>
          <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface max-w-xl">
            Retrouvez votre <span class="text-primary">sourire naturel</span> grâce aux implants.
          </h1>
          <p class="font-body-lg text-body-lg text-on-surface-variant max-w-lg">
            Une solution permanente et esthétique pour remplacer les dents manquantes, alliant précision chirurgicale et confort optimal pour une meilleure qualité de vie.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <AppointmentButton client:load label="Prendre RDV en ligne" phone="01 23 45 67 89" />
            <a
              class="border-2 border-primary text-primary px-8 py-4 rounded-xl font-bold hover:bg-primary/5 transition-all flex items-center justify-center gap-2"
              href="/services/implants-dentaires#cas"
            >
              Nos cas cliniques
              <span class="material-symbols-outlined">visibility</span>
            </a>
          </div>
          <div class="flex items-center gap-6 pt-4">
            <div class="flex -space-x-3">
              <img
                class="w-10 h-10 rounded-full border-2 border-surface object-cover"
                alt="Patient"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuBUiYLPuOHLXEgQC1McVhbhahFmDbqJ1d0D5h3KAEkuN4mPSlGrE2gUgYh_91BecaJLJH10SVKU3BXb1X1xAj6kWLpO37blYJSGaglZEsHEN_kBvXP3scQ30YQD990Esni541Ufo05Pzk8I8t76DcXNO2HlBPzQiBbvyqDyY9-u0c2zyqypB1u8gcN5VrYMLuyy74rJIGwLklFnHSRWh2ARP7Dy4boEjlYgeLnACEA8iLuxlAqKTIkAmk_AfboTq222nKvV1U-HmL0"
              />
              <img
                class="w-10 h-10 rounded-full border-2 border-surface object-cover"
                alt="Patient"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuCvz1wKH-q9kHBOZhrrcV5Blfhcp7prHA9LAgHIzPvRhaaIFUScrqkZLtLOhk50l-4veqdbubXJAYLVlkyTjQXcaAHu6gIy12KbFuig7nflKQts7ZAasQyquYtb7FDLrXw3b3vIh5ehmvQUzOIM-khA-nHXAeCPjbKvFgegcFK8Mq6i7KkDagJBW8Z6xwI-bmr5prNpoR5_S2ZyWStmRY442mn7v4bbJMXDqbpIc2_TYML38dTuqGF3tsa0A8HgcN3e9tc7vxSko6s"
              />
              <img
                class="w-10 h-10 rounded-full border-2 border-surface object-cover"
                alt="Patient"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuASOZke9KS6avLkLwxsWn3rKREQ85BG-ArrHGYWOa_hAyC1ixyXl7TPvKxN81pVrnA8iQ4axXpCm08bkE2VYI7qU9fv3tIqqeu9zswrWE7zz-6k_n2_ztVSHRpYSQJrymQG8quwmb6DdJvKKy02ysoSk7R3iD9X2xrHso9EWTjAcEsRezykf4Op-h6JI3vD3D6_MhtoLNc-i4mVahFQmR9xeSNmZmX2Ru2lPnf3ZXyOKJIR3tOS8-tuO0ugsZzKtxmgSxLDmKKuA7E"
              />
            </div>
            <div>
              <div class="flex gap-1 text-amber-500">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
              </div>
              <p class="text-label-md font-label-md text-on-surface-variant">Plus de 1000 patients satisfaits</p>
            </div>
          </div>
        </div>

        <div class="relative mt-12 lg:mt-0">
          <div class="relative z-10 rounded-[2rem] overflow-hidden border-8 border-surface-container-highest shadow-2xl">
            <img
              class="w-full aspect-[4/5] object-cover"
              alt="Salle de chirurgie dentaire moderne"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuB2xxuZGn1H4BLNCMsXJMMEmSO5Sl3JEbm-h-1MEALNS1i_i-5vrpZPu7Hpf7XqDMI-bP5S2x8j4F350790KyVBrObN6VlmwvhqfcpkwpWPfB92Vn71AWKKDrlvu6_He-7XzO4-vHDDC4Td_lsCTI8m1o2nRIMHZgSZi2deujV1u-IMWDNHyRpVFkGx1sYRhFvfVJlhrKpt6eV27ut4mBNPjc_lznVWIfPJ_BHv3MGDMxFrln9oDpsFwrZ4yOS7je7wI9fydD5JzOs"
            />
          </div>
          <div class="absolute -bottom-6 -left-6 z-20 bg-surface p-6 rounded-2xl shadow-xl border border-outline-variant max-w-[220px]">
            <span class="material-symbols-outlined text-primary text-4xl mb-2">verified</span>
            <h2 class="font-bold text-on-surface">Précision Chirurgicale</h2>
            <p class="text-[12px] text-on-surface-variant">
              Technologie 3D guidée pour une pose d'implant sécurisée.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-section-padding" id="cas">
      <div class="w-full px-6 lg:px-12">
        <div class="text-center mb-16 space-y-4 max-w-2xl mx-auto">
          <h2 class="font-headline-lg text-headline-lg text-on-surface">Pourquoi choisir l'implant dentaire ?</h2>
          <p class="text-on-surface-variant font-body-lg text-body-lg">
            Découvrez les avantages d'une solution durable qui va au-delà de l'esthétique simple.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="md:col-span-2 bg-surface-container-low p-8 rounded-3xl border border-outline-variant transition-all duration-300 hover:-translate-y-1 hover:shadow-xl flex flex-col md:flex-row gap-8 items-center">
            <div class="space-y-4 flex-1">
              <div class="w-12 h-12 bg-primary-container rounded-xl flex items-center justify-center text-on-primary-container">
                <span class="material-symbols-outlined text-3xl">skeleton</span>
              </div>
              <h3 class="font-headline-md text-headline-md">Préservation Osseuse</h3>
              <p class="text-on-surface-variant font-body-md">
                L'implant stimule l'os de la mâchoire comme une racine naturelle, évitant ainsi la résorption osseuse et le vieillissement prématuré du visage.
              </p>
            </div>
            <img
              class="w-full md:w-64 aspect-square object-cover rounded-2xl"
              alt="Modèle d'implant dentaire"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuAh0SwiXXd-ORpstT4r-vlt9ozmf1fipBaQs0SHtrW9FHUnDYEoPnA4RwIkfa9UAiYzP8NrGfw_DCUrALAGYC_RBh0YDHyXKz8zVxA-_QGoOJjEEgR0CVgZbzcgkA0tnNSR_HjaP2EmsJW4T0olNrpHTZhrJFWQ9PwIgciYzL8qpc2-WxPs5lspyX6wgQ1pu1TmKattWmvChHstNqS5Yo0cFAA47uVeliDGB5jWuzYqT98gcbo3bA3plg3erN30O-vwW2SCURQVYoc"
            />
          </div>

          <div class="bg-primary text-on-primary p-8 rounded-3xl transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <div class="space-y-4">
              <div class="w-12 h-12 bg-on-primary rounded-xl flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">favorite</span>
              </div>
              <h3 class="font-headline-md text-headline-md">Qualité de Vie</h3>
              <p class="opacity-90 font-body-md">
                Mangez, parlez et souriez sans gêne. Les implants offrent la même stabilité que vos dents naturelles.
              </p>
            </div>
          </div>

          <div class="bg-surface-container-low p-8 rounded-3xl border border-outline-variant transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <div class="space-y-4 text-center">
              <div class="w-12 h-12 bg-secondary-container rounded-full mx-auto flex items-center justify-center text-on-secondary-container">
                <span class="material-symbols-outlined text-3xl">face</span>
              </div>
              <h3 class="font-headline-md text-headline-md">Look Naturel</h3>
              <p class="text-on-surface-variant font-body-md">
                Conçues sur mesure, nos couronnes sur implants s'intègrent parfaitement à votre dentition.
              </p>
            </div>
          </div>

          <div class="md:col-span-2 bg-surface-container-highest p-8 rounded-3xl transition-all duration-300 hover:-translate-y-1 hover:shadow-xl flex flex-col md:flex-row-reverse gap-8 items-center">
            <div class="space-y-4 flex-1">
              <div class="w-12 h-12 bg-tertiary-container rounded-xl flex items-center justify-center text-on-tertiary-container">
                <span class="material-symbols-outlined text-3xl">all_inclusive</span>
              </div>
              <h3 class="font-headline-md text-headline-md">Une Solution Permanente</h3>
              <p class="text-on-surface-variant font-body-md">
                Avec une hygiène rigoureuse, un implant dentaire peut durer toute une vie. C'est l'investissement santé le plus durable.
              </p>
            </div>
            <div class="w-full md:w-64 bg-white/50 rounded-2xl p-6 flex items-center justify-center">
              <span class="material-symbols-outlined text-[120px] text-primary/20">clinical_notes</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-section-padding">
      <div class="w-full px-6 lg:px-12">
        <div class="bg-inverse-surface text-inverse-on-surface rounded-[2.5rem] p-8 md:p-16 relative overflow-hidden">
          <div class="relative z-10 max-w-2xl space-y-6">
            <h2 class="font-headline-lg text-headline-lg">Prêt à transformer votre sourire ?</h2>
            <p class="text-surface-variant font-body-lg">
              Prenez rendez-vous pour une consultation personnalisée et découvrez si l'implant est la solution idéale pour vous.
            </p>
            <div class="flex flex-wrap gap-4 items-center">
              <AppointmentButton client:load label="Prendre RDV maintenant" phone="01 23 45 67 89" />
              <div class="flex items-center gap-2 text-surface-variant font-bold">
                <span class="material-symbols-outlined text-primary-fixed">call</span>
                01 23 45 67 89
              </div>
            </div>
          </div>
          <div class="absolute right-0 top-0 h-full w-1/3 bg-primary/10 blur-[100px] rounded-full"></div>
          <div class="absolute -right-20 -bottom-20 opacity-10">
            <span class="material-symbols-outlined text-[400px]">medical_services</span>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .bg-soft-gradient {
    background: radial-gradient(circle at top left, rgba(104, 217, 202, 0.08) 0%, rgba(248, 250, 251, 1) 50%);
  }
</style>
