---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { AppointmentButton } from "../../components/AppointmentButton";
---

<BaseLayout title="Contact &amp; Prise de Rendez-vous - Dr PINTO KAREN">
  <Header />

  <main class="w-full">
    <section class="w-full bg-surface-container-low pt-section-padding pb-12 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-primary-container/10 to-transparent pointer-events-none"></div>
      <div class="w-full px-6 lg:px-12 flex flex-col md:flex-row items-center gap-8 relative z-10">
        <div class="w-full md:w-1/2">
          <span class="text-primary font-label-md text-label-md font-bold uppercase tracking-widest mb-3 block">
            NOUS SOMMES LÀ POUR VOUS
          </span>
          <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-6 leading-[1.1]">
            Gardons Votre Sourire Connecté
          </h1>
          <p class="font-body-lg text-body-lg text-on-surface-variant mb-8 max-w-lg leading-relaxed">
            Vous avez une question ou vous êtes prêt à prendre rendez-vous ? Notre équipe est heureuse de vous aider. N'hésitez pas à nous contacter à tout moment !
          </p>
        </div>

        <div class="w-full md:w-1/2 relative">
          <div class="rounded-xl overflow-hidden shadow-2xl h-[clamp(280px,40vw,420px)] bg-surface-container-high">
            <img
              alt="Une réceptionniste souriante portant un casque téléphonique dans un cabinet dentaire moderne et lumineux."
              class="w-full h-full object-cover"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuDq7x88Dr_v5N-q8VvcAVUGqYZc9b3IDuKJ9qLlzWdx85wcDse5T8BU5Uh2ev7SvHc6nNY40YGRXzdi2omS9zRflr5NAYahKcwA2G6WssYMc6uOJ9LJkPDw5_9u4Ig_jMS59iDqK5SA1jfwPyBZIxkJSN7ba5fEiCEbQK2VSGbCK0WhyZS1hPXtMq3QQdUApcYU6svXGphTogp4m859PpVLaqTsYF2MxWrqItW3NXGU9Jb6BClnCD62MmHiC3f7O_P3bizZU8VL-QE"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="w-full px-6 lg:px-12 py-12 -mt-20 relative z-20">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-1 flex flex-col gap-6">
          <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm flex items-start gap-4 hover:shadow-md transition-shadow">
            <div class="bg-primary-container/10 p-3 rounded-full text-primary flex-shrink-0">
              <span class="material-symbols-outlined">phone_iphone</span>
            </div>
            <div>
              <h2 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-1">Appelez-nous</h2>
              <p class="text-headline-md font-bold text-on-surface mb-2">05 22 20 26 12</p>
              <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">Lun - Sam, 9h00 - 18h00</p>
            </div>
          </div>

          <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm flex items-start gap-4 hover:shadow-md transition-shadow">
            <div class="bg-primary-container/10 p-3 rounded-full text-primary flex-shrink-0">
              <span class="material-symbols-outlined">mail</span>
            </div>
            <div>
              <h2 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-1">Email</h2>
              <p class="text-body-md font-bold text-on-surface mb-2">contact@dr-pinto.fr</p>
              <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">Nous répondons sous 1 jour ouvrable</p>
            </div>
          </div>

          <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm flex items-start gap-4 hover:shadow-md transition-shadow">
            <div class="bg-primary-container/10 p-3 rounded-full text-primary flex-shrink-0">
              <span class="material-symbols-outlined">schedule</span>
            </div>
            <div class="w-full">
              <h2 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-3">Horaires du Cabinet</h2>
              <div class="flex justify-between items-center mb-1 font-body-md text-body-md">
                <span class="text-on-surface-variant">Lun - Ven</span>
                <span class="font-bold text-on-surface">9:00 - 18:00</span>
              </div>
              <div class="flex justify-between items-center mb-1 font-body-md text-body-md">
                <span class="text-on-surface-variant">Samedi</span>
                <span class="font-bold text-on-surface">9:00 - 14:00</span>
              </div>
              <div class="flex justify-between items-center font-body-md text-body-md">
                <span class="text-on-surface-variant">Dimanche</span>
                <span class="font-bold text-error uppercase text-label-md">Fermé</span>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 bg-surface-container-lowest p-8 rounded-xl border border-outline-variant shadow-sm">
          <h2 class="font-headline-md text-headline-md text-on-surface mb-2">Envoyez-nous un message</h2>
          <p class="font-body-md text-body-md text-on-surface-variant mb-8">Nous serions ravis d'avoir de vos nouvelles.</p>

          <form class="space-y-6" method="POST">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block font-label-md text-label-md font-bold text-on-surface mb-2" for="fullName">Nom Complet</label>
                <input
                  class="w-full h-12 px-4 rounded-lg border border-surface-dim bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface placeholder-on-surface-variant/40"
                  id="fullName"
                  name="fullName"
                  placeholder="Votre nom complet"
                  type="text"
                />
              </div>
              <div>
                <label class="block font-label-md text-label-md font-bold text-on-surface mb-2" for="phone">Numéro de Téléphone</label>
                <input
                  class="w-full h-12 px-4 rounded-lg border border-surface-dim bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface placeholder-on-surface-variant/40"
                  id="phone"
                  name="phone"
                  placeholder="06 12 34 56 78"
                  type="tel"
                />
              </div>
            </div>

            <div>
              <label class="block font-label-md text-label-md font-bold text-on-surface mb-2" for="email">Adresse Email</label>
              <input
                class="w-full h-12 px-4 rounded-lg border border-surface-dim bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface placeholder-on-surface-variant/40"
                id="email"
                name="email"
                placeholder="vous@exemple.com"
                type="email"
              />
            </div>

            <div>
              <label class="block font-label-md text-label-md font-bold text-on-surface mb-2" for="message">Comment pouvons-nous vous aider ?</label>
              <textarea
                class="w-full p-4 rounded-lg border border-surface-dim bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface placeholder-on-surface-variant/40 resize-none"
                id="message"
                name="message"
                placeholder="Écrivez votre message ici..."
                rows="4"
              ></textarea>
            </div>

            <button
              class="w-full bg-primary text-on-primary font-label-md text-label-md py-4 rounded-lg hover:opacity-90 transition-all shadow-md flex justify-center items-center gap-2 font-bold uppercase tracking-wider"
              type="submit"
            >
              Envoyer le Message
              <span class="material-symbols-outlined text-[20px]">send</span>
            </button>
          </form>
        </div>
      </div>
    </section>

    <section class="w-full px-6 lg:px-12 py-section-padding border-t border-outline-variant/30">
      <div class="text-center mb-16">
        <h2 class="font-headline-lg text-headline-lg text-primary mb-4 leading-tight">Réservez Votre Visite en Quelques Minutes</h2>
        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">
          Simple. Rapide. Pratique. Planifiez votre rendez-vous en quelques étapes faciles.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 bg-surface-container-lowest p-8 rounded-xl border border-outline-variant shadow-sm">
          <div class="space-y-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div>
                <label class="block font-label-md text-label-md font-bold text-on-surface mb-3 uppercase tracking-wide">1. Sélectionnez le Service</label>
                <div class="relative">
                  <select
                    class="w-full h-12 px-4 appearance-none rounded-lg border border-surface-dim bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface cursor-pointer"
                  >
                    <option>Consultation Générale</option>
                    <option>Détartrage</option>
                    <option>Urgence Dentaire</option>
                    <option>Blanchiment</option>
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-on-surface-variant">
                    <span class="material-symbols-outlined">expand_more</span>
                  </div>
                </div>
              </div>
              <div>
                <label class="block font-label-md text-label-md font-bold text-on-surface mb-3 uppercase tracking-wide">2. Type de Patient</label>
                <div class="relative">
                  <select
                    class="w-full h-12 px-4 appearance-none rounded-lg border border-surface-dim bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface cursor-pointer"
                  >
                    <option>Nouveau Patient</option>
                    <option>Patient Existant</option>
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-on-surface-variant">
                    <span class="material-symbols-outlined">expand_more</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div>
                <label class="block font-label-md text-label-md font-bold text-on-surface mb-3 uppercase tracking-wide">3. Sélectionnez la Date</label>
                <input
                  class="w-full h-12 px-4 rounded-lg border border-surface-dim bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface cursor-pointer"
                  type="date"
                />
              </div>
              <div>
                <label class="block font-label-md text-label-md font-bold text-on-surface mb-3 uppercase tracking-wide">4. Sélectionnez l'Heure</label>
                <div class="relative">
                  <select
                    class="w-full h-12 px-4 appearance-none rounded-lg border border-surface-dim bg-surface-container-lowest focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all font-body-md text-on-surface cursor-pointer"
                  >
                    <option>Matin (9:00 - 12:00)</option>
                    <option>Après-midi (14:00 - 18:00)</option>
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-on-surface-variant">
                    <span class="material-symbols-outlined">expand_more</span>
                  </div>
                </div>
              </div>
            </div>

            <AppointmentButton client:load label="Confirmer le RDV" phone="05 22 20 26 12" />
          </div>
        </div>

        <div class="lg:col-span-1 bg-surface-container-lowest p-8 rounded-xl border border-outline-variant shadow-sm flex flex-col justify-between">
          <div>
            <h3 class="font-headline-md text-headline-md text-on-surface mb-8 border-b border-surface-dim pb-4 font-bold">Résumé du Rendez-vous</h3>
            <div class="space-y-6 mb-10">
              <div class="flex items-start gap-4">
                <div class="bg-primary-container/10 p-2 rounded-lg text-primary">
                  <span class="material-symbols-outlined text-[20px]">person</span>
                </div>
                <div>
                  <p class="font-label-md text-[clamp(10px,0.9vw,11px)] font-bold text-on-surface-variant/70 uppercase tracking-widest">Docteur</p>
                  <p class="font-body-md text-body-md font-bold text-on-surface">Dr. Pinto Karen</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="bg-primary-container/10 p-2 rounded-lg text-primary">
                  <span class="material-symbols-outlined text-[20px]">medical_services</span>
                </div>
                <div>
                  <p class="font-label-md text-[clamp(10px,0.9vw,11px)] font-bold text-on-surface-variant/70 uppercase tracking-widest">Service</p>
                  <p class="font-body-md text-body-md font-bold text-on-surface">À définir</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="bg-primary-container/10 p-2 rounded-lg text-primary">
                  <span class="material-symbols-outlined text-[20px]">calendar_today</span>
                </div>
                <div>
                  <p class="font-label-md text-[clamp(10px,0.9vw,11px)] font-bold text-on-surface-variant/70 uppercase tracking-widest">Date &amp; Heure</p>
                  <p class="font-body-md text-body-md font-bold text-on-surface">À définir</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="bg-primary-container/10 p-2 rounded-lg text-primary">
                  <span class="material-symbols-outlined text-[20px]">location_on</span>
                </div>
                <div>
                  <p class="font-label-md text-[clamp(10px,0.9vw,11px)] font-bold text-on-surface-variant/70 uppercase tracking-widest">Lieu</p>
                  <p class="font-body-md text-body-md font-bold text-on-surface leading-tight">131 Bd d'Anfa<br />4ème étage, Casablanca</p>
                </div>
              </div>
            </div>
          </div>

          <p class="text-center font-body-md text-[clamp(10px,0.9vw,11px)] font-medium text-on-surface-variant/60 flex items-center justify-center gap-1">
            <span class="material-symbols-outlined text-[14px]">event_busy</span>
            Annulation gratuite jusqu'à 24h avant.
          </p>
        </div>
      </div>
    </section>

    <section class="w-full px-6 lg:px-12 py-12">
      <h2 class="font-headline-md text-headline-md text-on-surface mb-8 font-bold">Notre Emplacement</h2>
      <div class="rounded-xl overflow-hidden border border-outline-variant shadow-sm h-[clamp(320px,45vw,520px)] relative bg-surface-container-low">
        <iframe
          class="w-full h-full"
          title="Carte OpenStreetMap - 131 Bd d'Anfa, Casablanca"
          src="https://www.openstreetmap.org/export/embed.html?bbox=-7.6384593%2C33.5845287%2C-7.6184593%2C33.6045287&layer=mapnik&marker=33.5945287%2C-7.6284593"
          style="border: 0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>

        <div class="absolute bottom-6 left-6 bg-surface/95 backdrop-blur-sm p-6 rounded-xl max-w-sm shadow-xl border border-outline-variant/50">
          <h3 class="font-label-md text-body-md font-bold text-on-surface mb-2">Cabinet Dentaire Dr PINTO</h3>
          <p class="font-body-md text-body-md text-on-surface-variant mb-6 leading-relaxed">
            131 Bd d'Anfa<br />4ème étage<br />Casablanca, Maroc
          </p>
          <a
            class="inline-flex items-center gap-2 text-primary hover:text-primary-container font-label-md text-body-md font-bold transition-colors group"
            href="https://www.openstreetmap.org/?mlat=33.5945287&mlon=-7.6284593#map=18/33.5945287/-7.6284593"
            target="_blank"
            rel="noreferrer"
          >
            <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">directions</span>
            Obtenir l'itinéraire
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-12 border-t border-outline-variant/30 pt-10">
        <div class="flex items-center gap-3 group">
          <div class="bg-primary-container/10 p-2.5 rounded-lg text-primary transition-colors group-hover:bg-primary-container/20">
            <span class="material-symbols-outlined">verified</span>
          </div>
          <p class="font-label-md text-body-md font-bold text-on-surface">Soins Personnalisés</p>
        </div>
        <div class="flex items-center gap-3 group">
          <div class="bg-primary-container/10 p-2.5 rounded-lg text-primary transition-colors group-hover:bg-primary-container/20">
            <span class="material-symbols-outlined">biotech</span>
          </div>
          <p class="font-label-md text-body-md font-bold text-on-surface">Technologie Moderne</p>
        </div>
        <div class="flex items-center gap-3 group">
          <div class="bg-primary-container/10 p-2.5 rounded-lg text-primary transition-colors group-hover:bg-primary-container/20">
            <span class="material-symbols-outlined">chair</span>
          </div>
          <p class="font-label-md text-body-md font-bold text-on-surface">Expérience Confortable</p>
        </div>
        <div class="flex items-center gap-3 group">
          <div class="bg-primary-container/10 p-2.5 rounded-lg text-primary transition-colors group-hover:bg-primary-container/20">
            <span class="material-symbols-outlined">emergency</span>
          </div>
          <p class="font-label-md text-body-md font-bold text-on-surface">Urgences Acceptées</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
